# ============================================================
# Пример конфигурации / Configuration template
# ============================================================
# Скопируй этот файл в .env и заполни своими ключами:
#   cp .env.example .env
#
# ВАЖНО: файл .env уже в .gitignore — НИКОГДА не коммить его!
# IMPORTANT: .env is in .gitignore — NEVER commit it!
# ============================================================

# --- MEXC API ---
# Получить на: https://www.mexc.com/user/openapi
MEXC_API_KEY=your_mexc_api_key_here
MEXC_SECRET_KEY=your_mexc_secret_key_here

# --- Telegram ---
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWXyz
# Твой chat_id (узнать у @userinfobot)
TELEGRAM_CHAT_ID=123456789

# --- Параметры анализа (опционально) / Analysis parameters (optional) ---
TRADING_PAIRS=BTC/USDT,ETH/USDT
TIMEFRAME=30m
# Таймфрейм для проверки исполнения ордеров и SL/TP (должен быть < TIMEFRAME)
CHECK_TIMEFRAME=5m
CANDLES_LIMIT=500
MIN_TOUCHES=3
TOLERANCE_PERCENT=0.5
EXTREMA_WINDOW=8
TOP_N_LEVELS=5
DELAY_BETWEEN_PAIRS=2
# Интервал между прогонами в часах (0 = одноразовый запуск)
RUN_INTERVAL_HOURS=0.05

# --- Критерии истинности уровней / Level quality criteria ---
# Минимальный промежуток между касаниями (в свечах)
MIN_TOUCH_SPACING=3
# Минимальный возраст уровня — количество свечей от конца данных
LEVEL_AGE_MIN_CANDLES=10
# Минимальный объём на касании: множитель от среднего (0 = фильтр отключён)
VOLUME_TOUCH_MULTIPLIER=1.2
# Требовать ретест после пробоя: true / false
REQUIRE_RETEST=false

# --- Точки входа / Entry signals ---
# Порог близости к уровню для генерации сигнала (% от цены)
ENTRY_PROXIMITY_PERCENT=0.5
# Период EMA для определения тренда (нужно >= CANDLES_LIMIT)
EMA_PERIOD=200
# Автоматически брать топ N пар по объёму (0 = использовать TRADING_PAIRS выше)
AUTO_TOP_PAIRS=0

# --- Динамические SL/TP (ATR + ближайший уровень S/R) ---
# Период ATR
ATR_PERIOD=14
# SL = entry ± ATR × SL_ATR_MULT
SL_ATR_MULT=1.5
# TP на ближайший уровень S/R, но не ближе чем ATR × TP_ATR_MIN_MULT от входа
# Должно быть >= SL_ATR_MULT × MIN_RR (1.5 × 1.5 = 2.25), иначе фоллбэк не пройдёт R:R фильтр
TP_ATR_MIN_MULT=2.5
# Минимальный R:R — сигналы с меньшим значением пропускаются
MIN_RR=1.5

# --- Многотаймфреймовый тренд + ADX ---
# Старший таймфрейм для определения тренда (рекомендуется 4h)
HTF_TIMEFRAME=4h
# EMA на старшем TF: цена выше = UP тренд, ниже = DOWN
HTF_EMA_PERIOD=50
# Период ADX для измерения силы тренда
ADX_PERIOD=14
# Минимальный ADX для открытия сделки (ниже = боковик, не торговать; 0 = фильтр отключён)
ADX_MIN=20

# --- Хранилище данных / Data storage ---
# Google Sheets (рекомендуется для хостинга)
# Инструкция:
#   1. Google Cloud Console → IAM → Service Accounts → создать → скачать JSON ключ
#   2. Создать таблицу Google Sheets, поделиться с email сервисного аккаунта (Editor)
#   3. Скопировать ID таблицы из URL: docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
# Вставь ВЕСЬ текст JSON ключа одной строкой (рекомендуется):
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
# Или укажи путь к файлу ключа (альтернатива GOOGLE_CREDENTIALS_JSON):
# GOOGLE_CREDENTIALS_FILE=./credentials.json
# Путь к файлам (используется если Google Sheets не настроен)
DATA_DIR=./

# --- Бумажная торговля / Paper trading ---
# Начальный баланс в долларах
INITIAL_BALANCE=1000
# Размер каждой сделки (% от баланса)
TRADE_SIZE_PERCENT=2
# Максимум одновременно открытых позиций (0 = без лимита, открывает по всем сигналам)
MAX_OPEN_TRADES=0
# Кредитное плечо (1 = без плеча, 10 = 10×)
LEVERAGE=10
# Резервный счётчик проверок до отмены ордера (ордера отменяются по близости к уровню, не по счётчику)
PENDING_EXPIRY_CHECKS=99999
